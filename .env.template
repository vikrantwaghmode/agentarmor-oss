# ===========================================
# AgentArmor Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Dashboard Access Tokens ---
# Change these to strong, unique values before deploying.
ADMIN_TOKEN="your-admin-secret-token"   # Full dashboard control + all repave actions
USER_TOKEN="your-user-secret-token"     # Read-only dashboard access

# --- LLM Provider ---
# Uncomment ONE. Defaults to openclaw if unset.
# LLM_PROVIDER="openclaw"   # Default — uses the embedded OpenClaw gateway
# LLM_PROVIDER="gemini"
# LLM_PROVIDER="openai"
# LLM_PROVIDER="anthropic"

# --- API Keys (for the provider selected above) ---
GEMINI_API_KEY=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# --- OpenClaw Gateway token (only when LLM_PROVIDER=openclaw) ---
# Auto-generated on first run if left empty.
OPENCLAW_GATEWAY_TOKEN=""

# -------------------------------------------------------------------
# High Availability (optional — single-container SQLite by default)
# -------------------------------------------------------------------

# PostgreSQL — replaces SQLite for the audit log, enabling multi-instance HA
# Format: postgres://user:password@host:5432/dbname?sslmode=disable
# DATABASE_URL="postgres://agentarmor:secret@postgres:5432/agentarmor?sslmode=disable"

# Redis — distributes rate-limit state across all proxy instances
# Format: redis://host:port  or  redis://:password@host:port
# REDIS_URL="redis://redis:6379"

# Prometheus metrics scrape endpoint — set a token to restrict access
# METRICS_TOKEN="your-scrape-token"

# -------------------------------------------------------------------
# OpenTelemetry Tracing (optional — disabled when endpoint is not set)
# -------------------------------------------------------------------
# Compatible with Jaeger, Grafana Tempo, Honeycomb, Datadog Agent, etc.
# See docker-compose.yml for an optional Jaeger sidecar.
#
# OTEL_EXPORTER_OTLP_ENDPOINT="http://jaeger:4318"   # OTLP/HTTP endpoint
# OTEL_SERVICE_NAME="agentarmor"                      # service name in traces
# OTEL_INSECURE="false"                               # set true to skip TLS verify

# -------------------------------------------------------------------
# WASM Filters (optional — drop .wasm files into ./wasm-filters/)
# -------------------------------------------------------------------
# No config needed — AgentArmor auto-loads any .wasm file in the directory.
# Manage from the Infrastructure tab (10) → WASM Filters section.
# See wasm-filters/README.md for the filter ABI and language examples.

# -------------------------------------------------------------------
# TLS — ALWAYS ON by default
# -------------------------------------------------------------------
# A self-signed certificate is generated automatically on first run
# and stored in ./certs/. All traffic runs on https://localhost:8443.
# http://localhost:8080 redirects to HTTPS automatically.
#
# For production, replace ./certs/server.crt and ./certs/server.key
# with a CA-signed certificate. No rebuild required — just restart.
#
# To use a certificate from a different path, set these:
# TLS_CERT="/app/certs/server.crt"   # path inside the container
# TLS_KEY="/app/certs/server.key"

# ACME / Let's Encrypt — automatic cert issuance + renewal (requires public domain + port 80)
# ACME_DOMAIN="proxy.example.com"
# ACME_EMAIL="ops@example.com"
# ACME_STAGING="false"   # set true to use Let's Encrypt staging (no rate limits, untrusted cert)

# --- CORS ---
# The proxy always allows its own origin (https://localhost:8443).
# List any additional origins that need cross-origin API access:
# AGENTARMOR_CORS_ORIGINS="https://dashboard.internal.example.com"

# -------------------------------------------------------------------
# SSO / OIDC (optional — set OIDC_ENABLED=true to activate)
# -------------------------------------------------------------------
# Works with any OIDC-compliant provider:
#   Google Workspace  → OIDC_ISSUER="https://accounts.google.com"
#   Okta              → OIDC_ISSUER="https://<your-domain>.okta.com"
#   Azure AD          → OIDC_ISSUER="https://login.microsoftonline.com/<tenant>/v2.0"
#   Keycloak          → OIDC_ISSUER="https://<host>/realms/<realm>"
#   Auth0             → OIDC_ISSUER="https://<tenant>.auth0.com/"
#
# Register a redirect URI in your provider:
#   https://<your-host>:8443/armor/callback
#
# When enabled, the dashboard shows an SSO login button.
# Static Bearer tokens still work as a fallback (service accounts / CLI).

# OIDC_ENABLED="true"
# OIDC_ISSUER="https://accounts.google.com"
# OIDC_CLIENT_ID="your-client-id"
# OIDC_CLIENT_SECRET="your-client-secret"
# OIDC_REDIRECT_URL="https://localhost:8443/armor/callback"

# Map OIDC groups/roles to AgentArmor roles (comma-separated)
# OIDC_ADMIN_GROUPS="security-admins,agentarmor-admins"
# OIDC_USER_GROUPS="employees,security-readers"

# Extra scopes beyond openid/email/profile (e.g. "groups" for Okta)
# OIDC_SCOPES="openid,email,profile,groups"
# Custom name for the SSO button (auto-detected from issuer if unset)
# OIDC_PROVIDER_NAME="Acme Corp SSO"

# -------------------------------------------------------------------
# Secrets Provider (optional — defaults to plain env vars)
# -------------------------------------------------------------------
# Set SECRETS_PROVIDER to load API keys from an external secrets backend.
# The backend must store a single secret containing a flat JSON object:
#   { "ADMIN_TOKEN": "...", "OPENAI_API_KEY": "...", ... }
# Loaded values override any same-named env var already set.
#
# SECRETS_PROVIDER=""   # env (default) | vault | aws | gcp | azure

# --- HashiCorp Vault (KV v2) ---
# SECRETS_PROVIDER="vault"
# VAULT_ADDR="https://vault.example.com:8200"
# VAULT_SECRET_PATH="secret/data/agentarmor"   # KV v2 mount + path
# VAULT_TOKEN="hvs.xxxxxxxxxxxx"               # static token — OR use AppRole:
# VAULT_ROLE_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# VAULT_SECRET_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
# VAULT_SKIP_VERIFY="false"   # set true only for self-signed Vault certs in dev

# --- AWS Secrets Manager ---
# SECRETS_PROVIDER="aws"
# AWS_REGION="us-east-1"
# AWS_SECRET_NAME="agentarmor/prod"
# AWS_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"      # omit to use EC2 instance profile
# AWS_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
# AWS_SESSION_TOKEN=""   # only needed for temporary STS credentials

# --- GCP Secret Manager ---
# SECRETS_PROVIDER="gcp"
# GCP_PROJECT_ID="my-project-123"
# GCP_SECRET_NAME="agentarmor-secrets"
# GCP_SECRET_VERSION="latest"                  # or pin to e.g. "3"
# GOOGLE_APPLICATION_CREDENTIALS="/run/secrets/sa-key.json"  # omit on GCE/GKE (metadata server used)

# --- Azure Key Vault ---
# SECRETS_PROVIDER="azure"
# AZURE_KEYVAULT_URL="https://myvault.vault.azure.net"
# AZURE_SECRET_NAME="agentarmor-secrets"       # secret value must be a JSON object
# AZURE_TENANT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"    # omit on Azure VMs/AKS
# AZURE_CLIENT_ID="xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"    # (managed identity used)
# AZURE_CLIENT_SECRET="your-client-secret"
