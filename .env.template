# ===========================================
# AgentArmor Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- AgentArmor Security ---
# Tokens for accessing the AgentArmor dashboard.
# Change these to strong, unique values.
ADMIN_TOKEN="your-admin-secret-token"
USER_TOKEN="your-user-secret-token"

# --- LLM Provider Selection ---
# Choose ONE provider. Uncomment the provider you want to use.
# If no provider is selected, AgentArmor will default to using the OpenClaw gateway.
# LLM_PROVIDER="openai"
# LLM_PROVIDER="anthropic"
# LLM_PROVIDER="gemini"
# LLM_PROVIDER="openclaw" # Default

# --- API Keys for LLM Providers ---
# Provide the key for the provider you selected above.
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""

# --- OpenClaw Gateway (only if LLM_PROVIDER="openclaw") ---
# If empty, a random token is auto-generated on first run.
OPENCLAW_GATEWAY_TOKEN=""
